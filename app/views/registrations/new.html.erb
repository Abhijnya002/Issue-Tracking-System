<div class="mx-auto max-w-md">
  <h1 class="text-2xl font-semibold tracking-tight">Create an account</h1>
  <p class="mt-2 text-sm text-slate-600">Use your work email. You will create projects and invite collaborators next.</p>

  <%= form_with model: @user, url: registration_path, class: "mt-8 space-y-5" do |form| %>
    <% if @user.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <ul class="list-inside list-disc">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :email_address, class: "block text-sm font-medium text-slate-700" %>
      <%= form.email_field :email_address, required: true, autocomplete: "username", class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= form.label :password, class: "block text-sm font-medium text-slate-700" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= form.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-slate-700" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= form.submit "Create account", class: "w-full rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-indigo-500" %>
    </div>
  <% end %>

  <p class="mt-6 text-center text-sm text-slate-600">
    Already have an account?
    <%= link_to "Sign in", new_session_path, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
  </p>
</div>
