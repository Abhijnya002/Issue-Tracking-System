<%# locals: (project:, issue:, assignees:, project_labels:) %>
<%= form_with model: [project, issue], class: "space-y-5" do |form| %>
  <% if issue.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
      <ul class="list-inside list-disc">
        <% issue.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_field :title, required: true, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_area :description, rows: 6, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :issue_type, class: "block text-sm font-medium text-slate-700" %>
      <%= form.select :issue_type, Issue::ISSUE_TYPES.map { |t| [t.humanize, t] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= form.label :priority, class: "block text-sm font-medium text-slate-700" %>
      <%= form.select :priority, Issue::PRIORITIES.map { |p| [p.humanize, p] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= form.label :status, class: "block text-sm font-medium text-slate-700" %>
      <%= form.select :status, Issue::STATUSES.map { |s| [s.tr("_", " ").humanize, s] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= form.label :assignee_id, "Assignee", class: "block text-sm font-medium text-slate-700" %>
      <%= form.collection_select :assignee_id, assignees, :id, :email_address, { include_blank: "Unassigned" }, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
  </div>

  <div class="rounded-lg border border-slate-200 bg-slate-50/90 p-4">
    <span class="block text-sm font-medium text-slate-800">Tags</span>
    <p class="mt-0.5 text-xs text-slate-500">Select tags for this issue. Add new tags with the form above, or <%= link_to "manage all tags", project_labels_path(project), class: "font-medium text-indigo-600 hover:text-indigo-500" %>.</p>

    <% if project_labels.any? %>
      <div class="mt-3 space-y-2 rounded-md border border-slate-200 bg-white p-3">
        <%= hidden_field_tag "issue[label_ids][]", "" %>
        <% project_labels.each do |lab| %>
          <label class="flex cursor-pointer items-center gap-3 rounded-md px-1 py-1 hover:bg-slate-50">
            <%= check_box_tag "issue[label_ids][]", lab.id, issue.label_ids.include?(lab.id),
                  id: dom_id(lab, :issue_pick),
                  class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
            <%= render "shared/label_badge", label: lab %>
          </label>
        <% end %>
      </div>
    <% else %>
      <p class="mt-2 text-sm text-slate-600">No tags yet — use <strong>Quick add tag</strong> above, then tick it here after the page reloads.</p>
    <% end %>
  </div>

  <div class="flex flex-wrap gap-3">
    <%= form.submit class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
    <%= link_to "Cancel", issue.persisted? ? project_issue_path(project, issue) : project_path(project), class: "rounded-md border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %>
  </div>
<% end %>
