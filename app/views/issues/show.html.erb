<% content_for :title, @issue.key %>

<div class="mx-auto max-w-3xl">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight"><%= @issue.title %></h1>
      <% if @issue.labels.any? %>
        <div class="mt-3 flex flex-wrap gap-1.5">
          <% @issue.labels.sort_by(&:name).each do |label| %>
            <%= render "shared/label_badge", label: label %>
          <% end %>
        </div>
      <% end %>
      <p class="mt-3 font-mono text-sm text-emerald-700"><%= @issue.key %></p>
      <div class="mt-3 flex flex-wrap gap-2">
        <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium uppercase text-slate-700"><%= @issue.issue_type %></span>
        <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium uppercase text-slate-700"><%= @issue.status.tr("_", " ") %></span>
        <span class="rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-medium uppercase text-amber-800"><%= @issue.priority %></span>
      </div>
    </div>
    <% role = @project.project_memberships.find_by(user: current_user)&.role %>
    <% if role.in?(%w[admin member]) %>
      <div class="flex gap-2">
        <%= link_to "Edit", edit_project_issue_path(@project, @issue), class: "rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50" %>
        <%= button_to "Delete", project_issue_path(@project, @issue), method: :delete, form: { data: { turbo_confirm: "Delete this issue?" } }, class: "rounded-md border border-red-200 bg-white px-3 py-2 text-sm font-medium text-red-700 shadow-sm hover:bg-red-50" %>
      </div>
    <% end %>
  </div>

  <dl class="mt-6 grid gap-4 border-y border-slate-200 py-6 sm:grid-cols-2">
    <div>
      <dt class="text-xs font-semibold uppercase tracking-wide text-slate-500">Reporter</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @issue.reporter.email_address %></dd>
    </div>
    <div>
      <dt class="text-xs font-semibold uppercase tracking-wide text-slate-500">Assignee</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @issue.assignee&.email_address || "Unassigned" %></dd>
    </div>
  </dl>

  <% if @issue.description.present? %>
    <div class="prose prose-slate mt-6 max-w-none">
      <h2 class="text-lg font-medium">Description</h2>
      <div class="mt-2 whitespace-pre-wrap text-slate-700"><%= @issue.description %></div>
    </div>
  <% end %>

  <section class="mt-10 border-t border-slate-200 pt-8">
    <h2 class="text-lg font-semibold">Comments</h2>

    <% if role.in?(%w[admin member]) %>
      <%= form_with model: [@project, @issue, Comment.new], url: project_issue_comments_path(@project, @issue), class: "mt-4 space-y-3" do |form| %>
        <%= form.text_area :body, rows: 3, placeholder: "Add a comment…", class: "block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        <%= form.submit "Comment", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
      <% end %>
    <% end %>

    <ul class="mt-8 space-y-6">
      <% @comments.each do |comment| %>
        <li class="border-b border-slate-100 pb-6 last:border-0">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-sm font-medium text-slate-900"><%= comment.user.email_address %></p>
              <p class="mt-1 text-xs text-slate-500"><%= time_ago_in_words(comment.created_at) %> ago</p>
              <div class="mt-2 whitespace-pre-wrap text-sm text-slate-700"><%= comment.body %></div>
            </div>
            <% if comment.user_id == current_user.id || current_user.admin_on?(@project) %>
              <%= button_to "Remove", project_issue_comment_path(@project, @issue, comment), method: :delete, form: { data: { turbo_confirm: "Remove this comment?" } }, class: "shrink-0 text-xs text-red-600 hover:text-red-500" %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  </section>

  <p class="mt-8">
    <%= link_to "← Back to board", project_path(@project), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
  </p>
</div>
