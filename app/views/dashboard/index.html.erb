<% content_for :title, "Projects" %>

<div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight">Projects</h1>
    <p class="mt-1 text-slate-600">Organize work with boards, issues, and reporting.</p>
  </div>
  <%= link_to "New project", new_project_path, class: "inline-flex items-center justify-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500" %>
</div>

<% if @projects.any? %>
  <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <% @projects.each do |project| %>
      <li>
        <%= link_to project_path(project), class: "block rounded-lg border border-slate-200 bg-white p-5 shadow-sm transition hover:border-indigo-200 hover:shadow" do %>
          <div class="flex items-start justify-between gap-2">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600"><%= project.key %></p>
              <h2 class="mt-1 text-lg font-medium text-slate-900"><%= project.name %></h2>
              <% if project.description.present? %>
                <p class="mt-2 line-clamp-2 text-sm text-slate-600"><%= project.description %></p>
              <% end %>
            </div>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="mt-10 rounded-lg border border-dashed border-slate-300 bg-white p-10 text-center">
    <p class="text-slate-600">No projects yet. Create one to start tracking issues.</p>
    <%= link_to "Create project", new_project_path, class: "mt-4 inline-flex rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
  </div>
<% end %>
