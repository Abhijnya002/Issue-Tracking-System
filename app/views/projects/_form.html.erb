<%= form_with model: project, class: "mt-8 space-y-5" do |form| %>
  <% if project.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
      <ul class="list-inside list-disc">
        <% project.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div
    x-data="{
      name: <%= (project.name || '').to_json %>,
      syncKey() {
        if (!<%= project.persisted?.to_json %>) {
          const k = this.name.replace(/[^A-Za-z0-9]+/g, '').toUpperCase().slice(0, 10)
          this.$refs.keyInput.value = k.length ? k : 'PRJ'
        }
      }
    }"
  >
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :name,
            class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500",
            "x-model": "name",
            "@input": "syncKey()" %>
    </div>

    <div>
      <%= form.label :key, "Project key", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :key,
            class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 font-mono uppercase shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500",
            "x-ref": "keyInput" %>
      <p class="mt-1 text-xs text-slate-500">For new projects, the key updates as you type the name (you can still edit it).</p>
    </div>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_area :description, rows: 4, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div class="flex flex-wrap gap-3">
    <%= form.submit class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
    <% if project.persisted? %>
      <%= link_to "Cancel", project_path(project), class: "rounded-md border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %>
    <% else %>
      <%= link_to "Cancel", root_path, class: "rounded-md border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %>
    <% end %>
  </div>
<% end %>
