<% content_for :title, "Report · #{@project.key}" %>

<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
  <div>
    <p class="text-sm font-medium text-indigo-600"><%= @project.key %></p>
    <h1 class="mt-1 text-3xl font-semibold tracking-tight">Project report</h1>
    <p class="mt-2 text-slate-600">Aggregations run as SQL against PostgreSQL for accurate reporting.</p>
  </div>
  <%= link_to "Back to board", project_path(@project), class: "rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50" %>
</div>

<div class="mt-10 grid gap-8 lg:grid-cols-2">
  <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold">Issues by status</h2>
    <table class="mt-4 w-full text-sm">
      <thead>
        <tr class="border-b border-slate-200 text-left text-slate-500">
          <th class="py-2 pr-4 font-medium">Status</th>
          <th class="py-2 font-medium">Count</th>
        </tr>
      </thead>
      <tbody>
        <% @status_rows.each do |row| %>
          <tr class="border-b border-slate-100">
            <td class="py-2 pr-4"><%= row["status"]&.tr("_", " ")&.humanize %></td>
            <td class="py-2 font-mono"><%= row["count"] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold">Open issues by priority</h2>
    <p class="mt-1 text-xs text-slate-500">Excludes done and cancelled.</p>
    <table class="mt-4 w-full text-sm">
      <thead>
        <tr class="border-b border-slate-200 text-left text-slate-500">
          <th class="py-2 pr-4 font-medium">Priority</th>
          <th class="py-2 font-medium">Count</th>
        </tr>
      </thead>
      <tbody>
        <% @priority_rows.each do |row| %>
          <tr class="border-b border-slate-100">
            <td class="py-2 pr-4"><%= row["priority"]&.humanize %></td>
            <td class="py-2 font-mono"><%= row["count"] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>

<section class="mt-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
  <h2 class="text-lg font-semibold">New issues per week (UTC)</h2>
  <p class="mt-1 text-xs text-slate-500">Last 12 weeks, from <code class="rounded bg-slate-100 px-1">date_trunc('week', …)</code>.</p>
  <table class="mt-4 w-full text-sm">
    <thead>
      <tr class="border-b border-slate-200 text-left text-slate-500">
        <th class="py-2 pr-4 font-medium">Week starting</th>
        <th class="py-2 font-medium">Created</th>
      </tr>
    </thead>
    <tbody>
      <% @weekly_rows.each do |row| %>
        <tr class="border-b border-slate-100">
          <td class="py-2 pr-4"><%= row["week"] && Time.zone.parse(row["week"].to_s).to_date %></td>
          <td class="py-2 font-mono"><%= row["count"] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<section class="mt-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
  <h2 class="text-lg font-semibold">Workload by assignee</h2>
  <p class="mt-1 text-xs text-slate-500">Members only; uses <code class="rounded bg-slate-100 px-1">FILTER (WHERE …)</code> aggregates.</p>
  <table class="mt-4 w-full text-sm">
    <thead>
      <tr class="border-b border-slate-200 text-left text-slate-500">
        <th class="py-2 pr-4 font-medium">Member</th>
        <th class="py-2 font-medium">Open</th>
        <th class="py-2 font-medium">Closed</th>
      </tr>
    </thead>
    <tbody>
      <% @assignee_rows.each do |row| %>
        <tr class="border-b border-slate-100">
          <td class="py-2 pr-4"><%= row["email_address"] %></td>
          <td class="py-2 font-mono"><%= row["open_issues"] %></td>
          <td class="py-2 font-mono"><%= row["closed_issues"] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
