<% content_for :title, "Labels · #{@project.key}" %>

<div class="mx-auto max-w-2xl">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-medium text-indigo-600"><%= @project.key %></p>
      <h1 class="text-2xl font-semibold tracking-tight">Labels</h1>
      <p class="mt-1 text-sm text-slate-600">Coloured tags for issues (like Jira). Names are unique per project.</p>
    </div>
    <%= link_to "New label", new_project_label_path(@project), class: "inline-flex justify-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500" %>
  </div>

  <% if @labels.any? %>
    <ul class="mt-8 divide-y divide-slate-200 rounded-lg border border-slate-200 bg-white shadow-sm">
      <% @labels.each do |label| %>
        <li class="flex items-center justify-between gap-4 px-4 py-3">
          <div class="flex min-w-0 items-center gap-3">
            <%= render "shared/label_badge", label: label %>
            <span class="truncate text-sm text-slate-500"><%= label.color.humanize %></span>
          </div>
          <div class="flex shrink-0 gap-2">
            <%= link_to "Edit", edit_project_label_path(@project, label), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
            <%= button_to "Delete", project_label_path(@project, label), method: :delete, form: { data: { turbo_confirm: "Remove this label from all issues?" } }, class: "text-sm font-medium text-red-600 hover:text-red-500" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-8 rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center text-slate-600">
      No labels yet. Create one to tag issues on the board.
    </p>
  <% end %>

  <p class="mt-8">
    <%= link_to "← Back to project", project_path(@project), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
  </p>
</div>
