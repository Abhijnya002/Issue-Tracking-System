<%= form_with model: [@project, label], class: "mt-8 space-y-5" do |form| %>
  <% if local_assigns[:return_to].present? %>
    <%= hidden_field_tag :return_to, local_assigns[:return_to] %>
  <% end %>
  <% if label.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
      <ul class="list-inside list-disc">
        <% label.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_field :name, required: true, placeholder: "e.g. Billing", class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= form.label :color, "Colour", class: "block text-sm font-medium text-slate-700" %>
    <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-3">
      <% Label::COLOR_OPTIONS.each do |key| %>
        <label class="flex cursor-pointer items-center gap-2 rounded-md border border-slate-200 p-2 hover:bg-slate-50 has-[:checked]:border-indigo-500 has-[:checked]:ring-1 has-[:checked]:ring-indigo-500">
          <%= form.radio_button :color, key, class: "border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
          <%= render "shared/label_badge", label: Label.new(name: "TAG", color: key) %>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex flex-wrap gap-3">
    <%= form.submit class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
    <%= link_to "Cancel", project_labels_path(@project), class: "rounded-md border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %>
  </div>
<% end %>
