<% content_for :title, "Team · #{@project.name}" %>

<div class="mx-auto max-w-2xl">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600"><%= @project.key %></p>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight">Team</h1>
      <p class="mt-1 text-sm text-slate-600">Everyone listed here can open this project on their dashboard and appear in the assignee list.</p>
    </div>
    <%= link_to "Back to project", project_path(@project), class: "shrink-0 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50" %>
  </div>

  <div class="mt-8 rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-sm font-semibold text-slate-900">Add someone</h2>
    <p class="mt-1 text-xs text-slate-500">They must already have an account. Enter the same email they used to sign up.</p>

    <%= form_with scope: :membership, url: project_memberships_path(@project), method: :post, class: "mt-4 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-end" do |f| %>
      <div class="min-w-0 flex-1">
        <%= f.label :email_address, "Email", class: "block text-sm font-medium text-slate-700" %>
        <%= f.email_field :email_address, required: true, autocomplete: "email", placeholder: "colleague@example.com", class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
      </div>
      <div class="w-full sm:w-40">
        <%= f.label :role, class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :role, ProjectMembership::ROLES.map { |r| [r.humanize, r] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.submit "Add to project", class: "w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 sm:w-auto" %>
      </div>
    <% end %>
  </div>

  <div class="mt-6">
    <h2 class="text-sm font-semibold text-slate-900">Members (<%= @memberships.size %>)</h2>
    <ul class="mt-3 divide-y divide-slate-200 rounded-lg border border-slate-200 bg-white shadow-sm">
      <% @memberships.each do |m| %>
        <li class="flex flex-wrap items-center justify-between gap-3 px-4 py-3">
          <div class="min-w-0">
            <p class="truncate font-medium text-slate-900"><%= m.user.email_address %></p>
            <p class="mt-0.5 text-xs text-slate-500">
              <%= m.role.humanize %>
              <% if m.user_id == @project.owner_id %>
                <span class="text-slate-400"> · Owner</span>
              <% end %>
            </p>
          </div>
          <% if m.user_id != @project.owner_id %>
            <%= button_to "Remove", project_membership_path(@project, m), method: :delete, data: { turbo_confirm: "Remove #{m.user.email_address} from this project?" }, class: "shrink-0 rounded-md border border-red-200 bg-white px-3 py-1.5 text-xs font-medium text-red-700 hover:bg-red-50" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
