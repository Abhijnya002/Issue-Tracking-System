<% if notice = flash[:notice] %>
  <div class="mb-4 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800" role="status"><%= notice %></div>
<% end %>
<% if alert = flash[:alert] %>
  <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800" role="alert"><%= alert %></div>
<% end %>
